{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "1xBet — Design System Officiel",
    "version": "1.0.0",
    "description": "Système de design basé sur l'identité visuelle officielle 1xBet. Fond bleu corporate #003087, CTA bleu électrique #1652f0, orange réservé aux promotions."
  },
  "color": {
    "background": {
      "dark":          { "$value": "#003087", "$type": "color", "$description": "Bleu corporate 1xBet — fond principal, header, nav" },
      "dark-2":        { "$value": "#002070", "$type": "color", "$description": "Sections alternées" },
      "dark-3":        { "$value": "#01195a", "$type": "color", "$description": "Cartes, panels" },
      "dark-4":        { "$value": "#012880", "$type": "color", "$description": "Hover, bordures" },
      "light":         { "$value": "#fdfcf7", "$type": "color", "$description": "Fond clair réservé" }
    },
    "accent": {
      "default": { "$value": "#f5a623", "$type": "color", "$description": "Orange — bonus, code promo, montants XOF" },
      "dim":     { "$value": "rgba(245,166,35,0.12)", "$type": "color", "$description": "Fond badge transparent" },
      "mid":     { "$value": "rgba(245,166,35,0.28)", "$type": "color", "$description": "Bordure, séparateur" },
      "glow":    { "$value": "rgba(245,166,35,0.38)", "$type": "color", "$description": "Box-shadow glow" },
      "dark":    { "$value": "#c47d00", "$type": "color", "$description": "Orange foncé — texte sur fond clair" }
    },
    "blue": {
      "default":     { "$value": "#1652f0", "$type": "color", "$description": "Bleu électrique — CTA, boutons d'action, liens" },
      "corporate":   { "$value": "#003087", "$type": "color", "$description": "Bleu corporate 1xBet — identique à --dark, utilisé comme token nommé" },
      "dark":        { "$value": "#0d3fd1", "$type": "color", "$description": "Hover des boutons bleus" },
      "dim":         { "$value": "rgba(22,82,240,0.14)", "$type": "color", "$description": "Fond transparent bleu" },
      "mid":         { "$value": "rgba(22,82,240,0.35)", "$type": "color", "$description": "Bordure bleue" },
      "glow":        { "$value": "rgba(22,82,240,0.42)", "$type": "color", "$description": "Box-shadow glow bleu" }
    },
    "green": {
      "default": { "$value": "#00c853", "$type": "color", "$description": "Badge LIVE, validation, gains" },
      "dim":     { "$value": "rgba(0,200,83,0.12)", "$type": "color", "$description": "Fond transparent vert" }
    },
    "neutral": {
      "white": { "$value": "#ffffff", "$type": "color" },
      "ink":   { "$value": "#ffffff", "$type": "color", "$description": "Texte principal (mode sombre)" }
    }
  },
  "borderRadius": {
    "card": { "$value": "18px", "$type": "dimension", "$description": "Cartes, panels" },
    "pill": { "$value": "999px", "$type": "dimension", "$description": "Boutons, badges" }
  },
  "typography": {
    "family": {
      "display": { "$value": "'Fraunces', serif",           "$type": "fontFamily", "$description": "Titres héro, éditoriaux" },
      "ui":      { "$value": "'Syne', sans-serif",          "$type": "fontFamily", "$description": "Corps, boutons, labels" },
      "mono":    { "$value": "'JetBrains Mono', monospace", "$type": "fontFamily", "$description": "Chiffres, cotes, codes" }
    }
  }
}
