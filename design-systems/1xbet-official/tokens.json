{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "1xBet — Design System Officiel",
    "version": "2.0.0",
    "description": "Tokens extraits directement du CSS officiel de 1xbetmaroc.com (genfiles/site-admin/colors). Mode clair, header bleu medium #266AA5, CTA vert lime #92C638, font Inter, radius 8px."
  },
  "color": {
    "brand": {
      "default":  { "$value": "#266AA5", "$type": "color", "$description": "Bleu corporate 1xBet — header, nav (hsl 208,62%,40%)" },
      "2":        { "$value": "#2B77B9", "$type": "color", "$description": "Sections (hsl 208,62%,45%)" },
      "3":        { "$value": "#3387D0", "$type": "color", "$description": "Hover / lighter (hsl 208,63%,51%)" },
      "deep":     { "$value": "#1C4268", "$type": "color", "$description": "Séparateurs dark (hsl 210,57%,26%)" },
      "sep":      { "$value": "#4780B2", "$type": "color", "$description": "Séparateurs sur bleu" }
    },
    "blue": {
      "default":  { "$value": "#3DA4FF", "$type": "color", "$description": "Bleu interactif — liens, actifs (hsl 208,100%,62%)" },
      "strong":   { "$value": "#2193F6", "$type": "color", "$description": "Hover (hsl 208,93%,55%)" }
    },
    "green": {
      "default":  { "$value": "#92C638", "$type": "color", "$description": "CTA principal officiel 1xBet — boutons S'inscrire, Se connecter, Déposer (hsl 82,56%,50%)" },
      "bright":   { "$value": "#A6E240", "$type": "color", "$description": "Badge LIVE, highlight (hsl 82,74%,57%)" },
      "dim":      { "$value": "rgba(146,198,56,0.14)", "$type": "color" },
      "mid":      { "$value": "rgba(146,198,56,0.32)", "$type": "color" },
      "glow":     { "$value": "rgba(146,198,56,0.45)", "$type": "color" }
    },
    "accent": {
      "default":  { "$value": "#f5a623", "$type": "color", "$description": "Orange — bonus, code promo, montants XOF (Flash Service)" },
      "dim":      { "$value": "rgba(245,166,35,0.12)", "$type": "color" },
      "mid":      { "$value": "rgba(245,166,35,0.28)", "$type": "color" },
      "glow":     { "$value": "rgba(245,166,35,0.38)", "$type": "color" },
      "dark":     { "$value": "#c47d00", "$type": "color" }
    },
    "bad": {
      "default":  { "$value": "#FE5659", "$type": "color", "$description": "Rouge erreur / perte (hsl 359,100%,67%)" },
      "dim":      { "$value": "rgba(254,86,89,0.12)", "$type": "color" }
    },
    "surface": {
      "bg":       { "$value": "#ffffff", "$type": "color", "$description": "Fond page" },
      "bg-2":     { "$value": "#f4f6f8", "$type": "color", "$description": "Sections alternées" },
      "bg-3":     { "$value": "#ffffff", "$type": "color", "$description": "Cartes" },
      "bg-hover": { "$value": "#eaeef2", "$type": "color" }
    },
    "ink": {
      "default":  { "$value": "#232323", "$type": "color", "$description": "Texte principal (hsl 0,0%,14%)" },
      "2":        { "$value": "#5a6470", "$type": "color", "$description": "Texte secondaire" },
      "mute":     { "$value": "#8a939e", "$type": "color", "$description": "Texte tertiaire / placeholder" },
      "on-brand": { "$value": "#ffffff", "$type": "color", "$description": "Texte sur fond bleu" }
    },
    "line": {
      "default":  { "$value": "#e3e7eb", "$type": "color", "$description": "Bordure légère" },
      "strong":   { "$value": "#c8cfd6", "$type": "color", "$description": "Bordure visible" }
    }
  },
  "borderRadius": {
    "card":  { "$value": "8px",   "$type": "dimension", "$description": "Cartes, inputs, boutons (officiel 1xBet)" },
    "pill":  { "$value": "999px", "$type": "dimension" }
  },
  "spacing": {
    "gutter": { "$value": "0.5rem", "$type": "dimension" },
    "gap":    { "$value": "8px",    "$type": "dimension" }
  },
  "typography": {
    "family": {
      "display": { "$value": "'Inter', system-ui, sans-serif",           "$type": "fontFamily" },
      "ui":      { "$value": "'Inter', system-ui, sans-serif",           "$type": "fontFamily" },
      "mono":    { "$value": "'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily" }
    }
  },
  "shadow": {
    "sm":  { "$value": "0 1px 2px rgba(0,0,0,0.06)",  "$type": "shadow" },
    "md":  { "$value": "0 2px 8px rgba(0,0,0,0.08)",  "$type": "shadow" },
    "lg":  { "$value": "0 8px 28px rgba(0,0,0,0.12)", "$type": "shadow" }
  }
}
