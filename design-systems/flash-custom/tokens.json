{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "Flash Service — Custom Design System",
    "version": "1.0.0",
    "description": "Système de design Flash Service. Fond navy sombre, bleu 1xBet pour les CTA, orange réservé aux promotions/bonus."
  },
  "color": {
    "background": {
      "dark":   { "$value": "#0d1b2a", "$type": "color", "$description": "Fond principal — navy sombre" },
      "dark-2": { "$value": "#0f2035", "$type": "color", "$description": "Sections alternées" },
      "dark-3": { "$value": "#132844", "$type": "color", "$description": "Cartes et panels" },
      "dark-4": { "$value": "#1a3350", "$type": "color", "$description": "Hover et bordures" },
      "light":  { "$value": "#fdfcf7", "$type": "color", "$description": "Fond clair (réservé)" }
    },
    "accent": {
      "default": { "$value": "#f5a623", "$type": "color", "$description": "Orange — bonus, code promo, highlights" },
      "dim":     { "$value": "rgba(245,166,35,0.12)", "$type": "color", "$description": "Orange très transparent" },
      "mid":     { "$value": "rgba(245,166,35,0.28)", "$type": "color", "$description": "Orange semi-transparent" },
      "glow":    { "$value": "rgba(245,166,35,0.38)", "$type": "color", "$description": "Orange pour box-shadow glow" },
      "dark":    { "$value": "#c47d00", "$type": "color", "$description": "Orange foncé — texte sur fond clair" }
    },
    "blue": {
      "default": { "$value": "#1652f0", "$type": "color", "$description": "Bleu électrique — CTA principal, nav bouton" },
      "dark":    { "$value": "#0d3fd1", "$type": "color", "$description": "Bleu foncé — hover CTA" },
      "dim":     { "$value": "rgba(22,82,240,0.14)", "$type": "color", "$description": "Bleu très transparent" },
      "mid":     { "$value": "rgba(22,82,240,0.35)", "$type": "color", "$description": "Bleu semi-transparent" },
      "glow":    { "$value": "rgba(22,82,240,0.42)", "$type": "color", "$description": "Bleu pour box-shadow glow" }
    },
    "green": {
      "default": { "$value": "#00c853", "$type": "color", "$description": "Vert — badge LIVE, gains, validation" },
      "dim":     { "$value": "rgba(0,200,83,0.12)", "$type": "color", "$description": "Vert très transparent" }
    },
    "neutral": {
      "white": { "$value": "#ffffff", "$type": "color" },
      "ink":   { "$value": "#ffffff", "$type": "color", "$description": "Couleur texte principale (mode sombre)" }
    }
  },
  "borderRadius": {
    "card": { "$value": "18px", "$type": "dimension", "$description": "Border radius cartes et panels" },
    "pill": { "$value": "999px", "$type": "dimension", "$description": "Border radius boutons et badges" }
  },
  "typography": {
    "family": {
      "display": { "$value": "'Fraunces', serif",        "$type": "fontFamily", "$description": "Titres éditoriaux, hero — italique gras" },
      "ui":      { "$value": "'Syne', sans-serif",       "$type": "fontFamily", "$description": "Corps, boutons, labels" },
      "mono":    { "$value": "'JetBrains Mono', monospace", "$type": "fontFamily", "$description": "Chiffres, codes, tags" }
    }
  }
}
